df = pd.read_csv('/content/Tata Chemicals Stock Price History.csv')

df

# Reset index if 'Date' is already the index
if 'Date' not in df.columns and df.index.name == 'Date':
    df = df.reset_index()

# Convert 'Date' to datetime and set as index only if not already
# Check if the index is not already a DatetimeIndex or if the index name is not 'Date'
if not isinstance(df.index, pd.DatetimeIndex) or df.index.name != 'Date':
    df['Date'] = pd.to_datetime(df['Date'])
    df = df.set_index('Date')

# Convert price-related columns to numeric
price_cols = ['Price', 'Open', 'High', 'Low']
for col in price_cols:
    if not pd.api.types.is_numeric_dtype(df[col]):
        df[col] = pd.to_numeric(df[col], errors='coerce')

# Clean 'Change %' column only if it's not already numeric
# Using pd.api.types.is_numeric_dtype for a robust check
if not pd.api.types.is_numeric_dtype(df['Change %']):
    df['Change %'] = df['Change %'].str.replace('%', '').astype(float) / 100

# Clean 'Vol.' column only if it's not already numeric
if not pd.api.types.is_numeric_dtype(df['Vol.']):
    def convert_volume(vol_str):
        if isinstance(vol_str, str):
            if 'M' in vol_str:
                return float(vol_str.replace('M', '')) * 1_000_000
            elif 'K' in vol_str:
                return float(vol_str.replace('K', '')) * 1_000
        return float(vol_str)
    df['Vol.'] = df['Vol.'].apply(convert_volume)


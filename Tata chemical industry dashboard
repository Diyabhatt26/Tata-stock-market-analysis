# Get min and max dates from the original DataFrame for initial widget values
# Ensure df is available and has a DatetimeIndex
if not isinstance(df.index, pd.DatetimeIndex):
    # This should ideally not happen if previous cells ran correctly,
    # but as a safeguard, convert 'Date' column to datetime and set as index.
    # Assumes 'Date' column exists if index is not DatetimeIndex
    if 'Date' in df.columns:
        df['Date'] = pd.to_datetime(df['Date'])
        df = df.set_index('Date')
    else:
        print("Warning: 'Date' column not found, interactive filtering might not work as expected.")

# Sort the DataFrame by its index to ensure it is monotonic for slicing
df.sort_index(inplace=True)

min_date = df.index.min().date()
max_date = df.index.max().date()

def create_dashboard(start_date, end_date):
    # Filter the DataFrame based on the selected date range
    filtered_df = df.loc[start_date.strftime('%Y-%m-%d'):end_date.strftime('%Y-%m-%d')]

    clear_output(wait=True) # Clear previous output before redrawing

    if filtered_df.empty:
        print("No data available for the selected date range.")
        return

    # Recalculate KPIs for the filtered data
    # Use .iloc[-1] for latest values, ensuring the index is sorted chronologically
    current_price = float(filtered_df['Price'].iloc[-1])
    total_volume = filtered_df['Vol.'].sum()
    latest_change_percent = filtered_df['Change %'].iloc[-1]

    # Display KPIs
    print(f"Current Price: {current_price:.2f}")
    print(f"Total Volume (Selected Period): {total_volume:,.0f}")
    print(f"Latest Change %: {latest_change_percent:.2%}")

    # Prepare data for monthly average price bar chart
    monthly_avg_price = filtered_df['Price'].resample('ME').mean()

    # Prepare data for yearly volume pie chart
    yearly_volume = filtered_df['Vol.'].groupby(filtered_df.index.year).sum()

    # Create a new figure for the dashboard layout
    fig_new = plt.figure(figsize=(18, 12))
    grid_new = fig_new.add_gridspec(2, 2, wspace=0.3, hspace=0.3)

    ax_bar = fig_new.add_subplot(grid_new[0, 0]) # Top-Left: Bar Chart
    ax_pie = fig_new.add_subplot(grid_new[0, 1]) # Top-Right: Pie Chart
    ax_line = fig_new.add_subplot(grid_new[1, 0]) # Bottom-Left: Line Chart

    # --- Top-Left: Monthly Average Price Bar Chart ---
    # Ensure monthly_avg_price is not empty before plotting
    if not monthly_avg_price.empty:
        sns.barplot(x=monthly_avg_price.index.strftime('%Y-%m'), y=monthly_avg_price.values, palette='viridis', ax=ax_bar, hue=monthly_avg_price.index.strftime('%Y-%m'), legend=False)
    ax_bar.set_title('Monthly Average Price')
    ax_bar.set_xlabel('Month-Year')
    ax_bar.set_ylabel('Average Price')
    ax_bar.tick_params(axis='x', rotation=90)

    # --- Top-Right: Yearly Volume Distribution Pie Chart ---
    if not yearly_volume.empty:
        ax_pie.pie(yearly_volume, labels=yearly_volume.index, autopct='%1.1f%%', startangle=90, colors=sns.color_palette('pastel'))
    ax_pie.set_title('Yearly Volume Distribution')
    ax_pie.axis('equal')

    # --- Bottom-Left: Stock Price Over Time Line Chart ---
    if not filtered_df.empty:
        ax_line.plot(filtered_df.index, filtered_df['Price'], color='blue')
    ax_line.set_title('Stock Price Over Time')
    ax_line.set_xlabel('Date')
    ax_line.set_ylabel('Price')
    ax_line.grid(True)

    # --- Bottom-Right: Candlestick Chart ---
    df_ohlc = filtered_df[['Open', 'High', 'Low', 'Price', 'Vol.']].copy()
    df_ohlc.rename(columns={'Price': 'Close', 'Vol.': 'Volume'}, inplace=True)
    df_ohlc.dropna(subset=['Open', 'High', 'Low', 'Close', 'Volume'], inplace=True)

    # Determine warn_too_much_data value for mplfinance
    warn_too_much_data_threshold = 1000 if len(df_ohlc) > 1000 else 0

    if not df_ohlc.empty:
        # Create a subgridspec for the candlestick and volume plots within the bottom-right grid cell
        gs_candlestick = grid_new[1, 1].subgridspec(2, 1, height_ratios=[3, 1], hspace=0.0)
        ax_candlestick_price = fig_new.add_subplot(gs_candlestick[0, 0])
        ax_candlestick_volume = fig_new.add_subplot(gs_candlestick[1, 0], sharex=ax_candlestick_price)

        mpf.plot(df_ohlc, type='candle', style='yahoo', ax=ax_candlestick_price, volume=ax_candlestick_volume,
                 show_nontrading=False, warn_too_much_data=warn_too_much_data_threshold)

        ax_candlestick_price.set_title('Candlestick Chart (Open, High, Low, Close)')
        ax_candlestick_price.set_xlabel('') # Clear x-label from price chart
        ax_candlestick_volume.set_xlabel('Date')
        ax_candlestick_price.set_ylabel('Price')
        ax_candlestick_volume.set_ylabel('Volume')
        ax_candlestick_price.grid(True)
        ax_candlestick_volume.grid(True)

    plt.tight_layout()
    plt.show()

# Define widgets
start_date_widget = widgets.DatePicker(
    description='Start Date',
    value=min_date,
    min=min_date,
    max=max_date,
    disabled=False
)

end_date_widget = widgets.DatePicker(
    description='End Date',
    value=max_date,
    min=min_date,
    max=max_date,
    disabled=False
)

# Use interactive_output to connect widgets to the function
# The output will be displayed in `interactive_plot`
interactive_plot = widgets.interactive_output(
    create_dashboard,
    {'start_date': start_date_widget, 'end_date': end_date_widget}
)

# Display widgets and the interactive plot
display(widgets.HBox([start_date_widget, end_date_widget]), interactive_plot)